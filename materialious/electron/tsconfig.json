{
  "compileOnSave": true,
  "include": [
    "./src/**/*",
    "./capacitor.config.ts",
    "./capacitor.config.js"
  ],
  "compilerOptions": {
    "outDir": "./build",
    "importHelpers": true,
    "target": "ES2017",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "typeRoots": [
      "./node_modules/@types"
    ],
    "allowJs": true,
    "rootDir": ".",
    "skipLibCheck": true
  }
}
